#usda 1.0
(
    doc = """Generated from Composed Stage of root layer 
"""
    upAxis = "Y"
)

def Xform "World"
{
    def Xform "Geometry"
    {
        def Sphere "RedSphere" (
            apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Looks/RedMaterial>
            double radius = 1
            double3 xformOp:translate = (-3, 1, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Sphere "RoughPlasticSphere" (
            apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Looks/RoughPlastic>
