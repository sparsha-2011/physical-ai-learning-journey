    }

    def SphereLight "ConeLight" (
        apiSchemas = ["ShapingAPI"]
    )
    {
        color3f inputs:color = (1, 1, 0.7)
        float inputs:intensity = 100000
        float inputs:radius = 0.3
        float inputs:shaping:cone:angle = 20
        float inputs:shaping:cone:softness = 0.1
        float inputs:shaping:focus = 5
        float3 xformOp:rotateXYZ = (-90, 0, 0)
        double3 xformOp:translate = (40, 15, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
