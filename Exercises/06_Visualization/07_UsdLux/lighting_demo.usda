def Scope "Lights"
{
    def DistantLight "DistantLight"
    {
        float inputs:angle = 0.53
        color3f inputs:color = (1, 0.95, 0.85)
        float inputs:intensity = 5000
        float3 xformOp:rotateXYZ = (-45, 0, 0)
        double3 xformOp:translate = (-60, 20, 10)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }

    def SphereLight "SphereLight"
    {
        color3f inputs:color = (1, 0.8, 0.6)
        float inputs:intensity = 80000
        float inputs:radius = 0.5
        double3 xformOp:translate = (-40, 8, 5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def RectLight "RectLight"
    {
        color3f inputs:color = (0.9, 0.95, 1)
        float inputs:height = 6
        float inputs:intensity = 8000
        float inputs:width = 6
        float3 xformOp:rotateXYZ = (-40, 0, 0)
        double3 xformOp:translate = (-20, 10, 8)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }

    def DiskLight "DiskLight"
    {
        color3f inputs:color = (0.8, 1, 0.9)
